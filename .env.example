# Tailscale hostname deines Pi, z.B. raspberrypi.tail12345.ts.net
RP_ID=dein-pi.tail12345.ts.net

# Muss exakt mit der URL übereinstimmen, die dein Browser sieht
RP_ORIGIN=https://dein-pi.tail12345.ts.net

# Anzeigename in der WebAuthn-Registrierung
RP_NAME=OpenDoor

# Zufälliger Secret-Key für Session-Cookies (mindestens 32 Zeichen)
# Generieren mit: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=HIER_ZUFAELLIGEN_STRING_EINSETZEN

# GPIO-Pin (BCM-Nummerierung) für Relais 1 — Haustür
RELAY_PIN=17

# true = Relais schaltet bei LOW (typisch für 4-Kanal-Boards), false = HIGH
RELAY_ACTIVE_LOW=true

# Wie lange das Relais geschlossen bleibt (Sekunden)
BUZZ_DURATION=3.0
